<!-- Site Header Component -->
<header class="site-header">
  <nav class="site-nav">
    <a href="{{ '/' | relative_url }}" class="site-title">{{ site.title }}</a>
    <div class="nav-links" data-global-top-nav>
      {% for section in docs_nav.sections %}<a href="{{ section.url | relative_url }}" data-doc-section="{{ section.id }}">{{ section.label }}</a>{% endfor %}
      <a href="{{ '/blog/' | relative_url }}">Blog</a>
      <a href="https://github.com/vicentereig/dspy.rb" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
  </nav>
</header>
