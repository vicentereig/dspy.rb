<!-- Head Component -->
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- SEO and Open Graph tags (generates title, description, og tags, canonical) -->
  {% seo %}
  
  <!-- Font preloads -->
  <link rel="preload" href="{{ '/fonts/newsreader-variable.woff2' | relative_url }}" as="font" type="font/woff2" crossorigin>
  <link rel="preload" href="{{ '/fonts/manrope-variable.woff2' | relative_url }}" as="font" type="font/woff2" crossorigin>

  <!-- Styles -->
  <link rel="stylesheet" href="{{ '/_bridgetown/static/css/index.css' | relative_url }}">
  <!-- Charts.css for data visualization -->
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/charts.css/dist/charts.min.css">
  
  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="{{ '/favicon.svg' | absolute_url }}">
  
  <!-- Sitemap -->
  <link rel="sitemap" type="application/xml" title="Sitemap" href="{{ '/sitemap.xml' | relative_url }}">
  
  <!-- JavaScript -->
  <script defer src="{{ '/_bridgetown/static/js/index.js' | relative_url }}"></script>
  
  <!-- Structured Data -->
  {% render "structured_data",
    dspy_version: site.config.dspy_version,
    page_relative_url: page.relative_url,
    page_schema_type: page.schema_type,
    page_canonical_url: page.canonical_url,
    page_title: page.title,
    page_description: page.description,
    page_date: page.date,
    page_last_modified_at: page.last_modified_at,
    page_image: page.image
  %}
</head>
