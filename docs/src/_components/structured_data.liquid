{% unless page_relative_url contains '/404' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "@id": "https://oss.vicente.services/dspy.rb/#website",
      "name": "DSPy.rb",
      "url": "https://oss.vicente.services/dspy.rb/",
      "description": "Documentation for DSPy.rb, a Ruby framework for typed AI agents and model-backed programs.",
      "inLanguage": "en"
    },
    {
      "@type": "SoftwareSourceCode",
      "@id": "https://oss.vicente.services/dspy.rb/#software",
      "name": "DSPy.rb",
      "description": "Build typed agents and model-backed programs in Ruby with signatures, tools, bounded execution, evaluation, and prompt optimization.",
      "url": "https://oss.vicente.services/dspy.rb/",
      "codeRepository": "https://github.com/vicentereig/dspy.rb",
      "programmingLanguage": "Ruby",
      "runtimePlatform": "Ruby",
      "license": "https://github.com/vicentereig/dspy.rb/blob/main/LICENSE",
      "version": {{ dspy_version | jsonify }},
      "author": {
        "@id": "https://oss.vicente.services/dspy.rb/#maintainer"
      }
    },
    {
      "@type": "Person",
      "@id": "https://oss.vicente.services/dspy.rb/#maintainer",
      "name": "Vicente Reig Rincón de Arellano",
      "url": "https://vicente.services",
      "sameAs": [
        "https://github.com/vicentereig"
      ]
    }{% if page_schema_type == 'TechArticle' %},
    {
      "@type": "TechArticle",
      "@id": {{ page_canonical_url | append: '#article' | jsonify }},
      "headline": {{ page_title | jsonify }},
      "description": {{ page_description | jsonify }},
      "url": {{ page_canonical_url | jsonify }},
      "datePublished": {{ page_date | date_to_xmlschema | jsonify }},
      "dateModified": {{ page_last_modified_at | default: page_date | date_to_xmlschema | jsonify }},
      "author": {
        "@id": "https://oss.vicente.services/dspy.rb/#maintainer"
      },
      "publisher": {
        "@id": "https://oss.vicente.services/dspy.rb/#maintainer"
      },
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": {{ page_canonical_url | jsonify }}
      }{% if page_image %},
      "image": {{ 'https://oss.vicente.services/dspy.rb' | append: page_image | jsonify }}{% endif %}
    }{% endif %}
  ]
}
</script>
{% endunless %}
