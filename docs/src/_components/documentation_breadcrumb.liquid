{% assign current_item = nil %}
{% assign current_section = nil %}
{% for item in docs_nav.items %}{% if item.status == "published" and current_url == item.url %}{% assign current_item = item %}{% endif %}{% endfor %}
{% if current_item %}{% for section in docs_nav.sections %}{% if section.id == current_item.section %}{% assign current_section = section %}{% endif %}{% endfor %}
<nav class="mb-8" aria-label="Breadcrumb" data-doc-breadcrumb>
  <ol role="list" class="flex items-center space-x-2 text-sm">
    <li><a href="{{ '/' | relative_url }}" aria-label="Home" class="text-ink-3 hover:text-ink"><span aria-hidden="true">⌂</span></a></li>
    {% unless current_item.url == current_section.url %}<li class="flex items-center"><span class="text-rule">/</span><a href="{{ current_section.url | relative_url }}" class="ml-2 text-ink-3 hover:text-ink">{{ current_section.label }}</a></li>{% endunless %}
    <li class="flex items-center" aria-current="page"><span class="text-rule">/</span><span class="ml-2 text-ink-2" data-doc-path="{{ current_item.url }}">{{ current_item.label }}</span></li>
  </ol>
</nav>
{% endif %}
