<!DOCTYPE html>
<html lang="en" class="h-full">
{% render "head", title_suffix: "DSPy.rb - Build Reliable LLM Applications in Ruby" %}
<body class="h-full font-sans">
  <div class="bg-white">
    {% render "header" %}

    <!-- Main Content -->
    <div class="px-6 pt-20 lg:px-8">
      <div class="mx-auto max-w-2xl py-16">
        <!-- Simple Header -->
        <header class="mb-12">
          <h1 class="font-serif text-2xl font-medium tracking-tight text-gray-900 sm:text-3xl" style="letter-spacing: -0.02em;">
            Learning in Drublic
          </h1>
          <p class="mt-2 text-base text-gray-500" style="font-family: 'Newsreader', Georgia, serif;">
            No BS AI development: practical Ruby tutorials that actually work.
          </p>
        </header>

        <!-- Blog posts list -->
        {% assign blog_posts = collections.articles.resources %}
        {% if blog_posts.size > 0 %}
          <ul class="space-y-6" style="list-style: none; padding: 0; margin: 0;">
            {% for post in blog_posts %}
              <li>
                <a href="{{ post.relative_url }}" class="text-dspy-coral underline hover:text-gray-900" style="text-underline-offset: 3px; font-family: 'Newsreader', Georgia, serif; font-size: 1.0625rem;">
                  {{ post.data.title }}
                </a>
                {% if post.data.description %}
                <p class="mt-1 text-sm text-gray-500 leading-snug" style="font-family: 'Newsreader', Georgia, serif;">
                  {{ post.data.description }}
                </p>
                {% endif %}
              </li>
            {% endfor %}
          </ul>
        {% else %}
          <p class="text-gray-500" style="font-family: 'Newsreader', Georgia, serif;">No posts yet. Check back soon.</p>
        {% endif %}
      </div>
    </div>
  </div>

  {% render "footer" %}
</body>
</html>
